# ── Stripe (required for Concierge checkout) ────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Create a Price in Stripe for the $999 concierge product and paste the ID here
STRIPE_CONCIERGE_PRICE_ID=price_...

# URL where Stripe should redirect on success/cancel
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Admin auth (required to access /admin) ──────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-now

# ── Phase 1 follow-up automation (vendor leads) ─────────────────────────────
BOOKING_URL=https://calendly.com/your-team/demo
OUTREACH_FROM_EMAIL=ops@weddingful.com
RESEND_API_KEY=re_...
